// whitelabel
export const FLAG_ENABLE_FEATURE_A = true;

// whitelabel *
export const GLOBAL_FEATURE = "I am distributed everywhere!";

// We intentionally do NOT implement V1_ONLY_FEATURE for def.
// Because it is 'optional', the registry will safely inject `undefined`.
