// AUTO-GENERATED: DO NOT EDIT

import type { WhitelabelConfig } from "./whitelabel";
export class whitelabel implements WhitelabelConfig {
  public get TITLE(): WhitelabelConfig["TITLE"] {
    return require("../content").TITLE;
  }
