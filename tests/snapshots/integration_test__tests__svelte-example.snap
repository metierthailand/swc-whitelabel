--- src/lib/index.ts ---
import whitelabel from "./whitelabel";
import { TITLE as _TITLE } from "$lib/content";
import { count as _count, onclick as _onclick } from "store";
export const count = _count;
export const onclick = whitelabel.onclick;
export const TITLE = whitelabel.TITLE;


--- src/lib/store.ts ---
import { writable } from "svelte/store";

export const count = writable(0);

// whitelabel *
export function onclick() {
  count.update((c) => c + 1);
}


